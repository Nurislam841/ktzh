{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS"
    },
    "deploy": {
        "numReplicas": 1,
        "sleepApplication": false
    },
    "services": {
        "backend": {
            "builder": "NIXPACKS",
            "rootDir": "backend",
            "buildCommand": "npm run build",
            "startCommand": "npm run start:prod",
            "env": {
                "NODE_ENV": "production",
                "PORT": "3001"
            }
        },
        "frontend": {
            "builder": "NIXPACKS",
            "rootDir": "frontend",
            "buildCommand": "npm run build",
            "startCommand": "npm run start",
            "env": {
                "NODE_ENV": "production",
                "PORT": "3000"
            }
        }
    }
}
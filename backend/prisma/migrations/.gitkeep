-- CreateEnum
CREATE TYPE "TrackStatus" AS ENUM ('FREE', 'OCCUPIED', 'MAINTENANCE');
CREATE TYPE "LocomotiveStatus" AS ENUM ('AVAILABLE', 'EN_ROUTE', 'MAINTENANCE', 'FAILED');
CREATE TYPE "CrewStatus" AS ENUM ('AVAILABLE', 'ASSIGNED', 'RESTING', 'UNAVAILABLE');
CREATE TYPE "TrainPriority" AS ENUM ('PASSENGER', 'FREIGHT', 'OTHER');
CREATE TYPE "TrainRunStatus" AS ENUM ('PLANNED', 'ACTIVE', 'DEPARTED', 'ARRIVED', 'CANCELLED');
CREATE TYPE "OperationalEventType" AS ENUM ('LOCOMOTIVE_FAILURE', 'CREW_UNAVAILABLE', 'TRAIN_DELAY', 'TRACK_BLOCKED', 'MAINTENANCE_STARTED', 'MAINTENANCE_ENDED');

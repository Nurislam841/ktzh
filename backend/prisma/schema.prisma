// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["ktz"]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TrackStatus {
  FREE
  OCCUPIED
  MAINTENANCE

  @@schema("ktz")
}

enum LocomotiveStatus {
  AVAILABLE
  ASSIGNED
  IN_TRANSIT
  MAINTENANCE

  @@schema("ktz")
}

enum CrewStatus {
  AVAILABLE
  ASSIGNED
  RESTING
  UNAVAILABLE

  @@schema("ktz")
}

enum TrainPriority {
  PASSENGER
  FREIGHT
  OTHER

  @@schema("ktz")
}

enum TrainRunStatus {
  PLANNED
  READY
  WAITING_SLOT
  LOCO_ASSIGNED
  CREW_CONFIRMED
  DELAYED
  DEPARTED
  CANCELLED
  // Legacy values kept for backward compatibility
  ACTIVE
  ARRIVED

  @@schema("ktz")
}

enum OperationScenario {
  FORMATION
  TRANSIT

  @@schema("ktz")
}

enum DepartureSlotStatus {
  IMMEDIATE
  ASSIGNED
  WAITING_QUEUE

  @@schema("ktz")
}

enum ScheduleApprovalMode {
  AUTOMATIC
  MANUAL

  @@schema("ktz")
}

enum ScheduleApprovalStatus {
  PENDING
  APPROVED
  REJECTED

  @@schema("ktz")
}

enum OperationalEventType {
  TRACK_CLOSURE
  LOCOMOTIVE_FAILURE
  CREW_ABSENCE
  LATE_TRAIN
  MAINTENANCE
  WEATHER
  CAPACITY_CONFLICT

  // Backward-compatible aliases for legacy clients
  CREW_UNAVAILABLE
  TRAIN_DELAY
  TRACK_BLOCKED
  MAINTENANCE_STARTED
  MAINTENANCE_ENDED

  @@schema("ktz")
}

enum CrewCallStatus {
  PLANNED
  NOTIFIED
  CONFIRMED
  MISSED
  CANCELLED

  @@schema("ktz")
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Station {
  id        String   @id @default(uuid())
  name      String
  code      String?  @unique
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  tracks           Track[]
  locomotives      Locomotive[]   @relation("StationLocomotives")
  trainRunsOrigin  TrainRun[]    @relation("OriginStation")
  trainRunsDest    TrainRun[]    @relation("DestStation")
  scheduleVersions ScheduleVersion[]
  events           OperationalEvent[]
  shouldersFrom    ServiceShoulder[] @relation("ShoulderFrom")
  shouldersTo      ServiceShoulder[] @relation("ShoulderTo")
  routeStops       RouteStop[]
  bindingsTurnaround BindingPlan[] @relation("BindingTurnaround")

  @@schema("ktz")
}

model Track {
  id              String      @id @default(uuid())
  stationId       String
  name            String
  status          TrackStatus @default(FREE)
  maintenanceFrom DateTime?
  maintenanceTo   DateTime?

  station     Station      @relation(fields: [stationId], references: [id])
  allocations Allocation[]

  @@index([stationId, status])
  @@schema("ktz")
}

model Depot {
  id   String @id @default(uuid())
  name String

  locomotives Locomotive[]
  crews       Crew[]
  shoulders   ServiceShoulder[]

  @@schema("ktz")
}

model Locomotive {
  id                String           @id @default(uuid())
  series            String
  number            String
  depotId           String
  locationStationId String?
  status            LocomotiveStatus @default(AVAILABLE)
  availableFrom     DateTime         @default(now())
  maintenanceFrom   DateTime?
  maintenanceTo     DateTime?

  depot           Depot    @relation(fields: [depotId], references: [id])
  locationStation Station? @relation("StationLocomotives", fields: [locationStationId], references: [id])
  allocations     Allocation[]
  bindingAllocations BindingAllocation[]

  @@index([status, availableFrom])
  @@schema("ktz")
}

model Crew {
  id                   String     @id @default(uuid())
  depotId              String
  status               CrewStatus @default(AVAILABLE)
  availableFrom        DateTime   @default(now())
  requiredNoticeMinutes Int       @default(120)

  depot       Depot        @relation(fields: [depotId], references: [id])
  allocations Allocation[]
  crewCalls   CrewCall[]

  @@index([status, availableFrom])
  @@schema("ktz")
}

model Train {
  id       String        @id @default(uuid())
  number   String        @unique
  priority TrainPriority @default(OTHER)
  route    String?
  frequency String?
  wagons   Int?
  carrier  String?

  trainRuns TrainRun[]
  schedules Schedule[]
  routes    Route[]
  bindingsArrival   BindingPlan[] @relation("BindingArrival")
  bindingsDeparture BindingPlan[] @relation("BindingDeparture")

  @@schema("ktz")
}

model TrainRun {
  id                   String         @id @default(uuid())
  trainId              String
  originStationId      String
  destinationStationId String
  scheduledDeparture   DateTime
  scheduledArrival     DateTime
  currentDelayMinutes  Int            @default(0)
  status               TrainRunStatus @default(PLANNED)
  operationScenario    OperationScenario @default(TRANSIT)
  requiresCrewChange   Boolean        @default(true)
  requiresLocoChange   Boolean        @default(false)

  train               Train      @relation(fields: [trainId], references: [id])
  originStation       Station    @relation("OriginStation", fields: [originStationId], references: [id])
  destinationStation  Station    @relation("DestStation", fields: [destinationStationId], references: [id])
  allocations         Allocation[]
  crewCalls           CrewCall[]

  @@index([scheduledDeparture])
  @@schema("ktz")
}

model ScheduleVersion {
  id              String  @id @default(uuid())
  stationId       String
  createdAt       DateTime @default(now())
  createdByUserId String?
  reason          String
  baseVersionId   String?
  approvalMode    ScheduleApprovalMode   @default(AUTOMATIC)
  approvalStatus  ScheduleApprovalStatus @default(APPROVED)
  approvedAt      DateTime?
  approvedByUserId String?

  station     Station      @relation(fields: [stationId], references: [id])
  baseVersion ScheduleVersion?  @relation("VersionHistory", fields: [baseVersionId], references: [id])
  childVersions ScheduleVersion[] @relation("VersionHistory")
  allocations Allocation[]
  crewCalls   CrewCall[]

  @@schema("ktz")
}

model Allocation {
  id                  String   @id @default(uuid())
  scheduleVersionId   String
  trainRunId          String
  plannedDeparture    DateTime
  plannedArrival      DateTime
  slotStatus          DepartureSlotStatus @default(ASSIGNED)
  assignedTrackId     String?
  assignedLocomotiveId String?
  assignedCrewId      String?
  conflictFlags       Json     @default("{}")
  notes               String   @default("")

  scheduleVersion  ScheduleVersion @relation(fields: [scheduleVersionId], references: [id])
  trainRun         TrainRun        @relation(fields: [trainRunId], references: [id])
  assignedTrack    Track?          @relation(fields: [assignedTrackId], references: [id])
  assignedLocomotive Locomotive?   @relation(fields: [assignedLocomotiveId], references: [id])
  assignedCrew     Crew?           @relation(fields: [assignedCrewId], references: [id])

  @@index([scheduleVersionId])
  @@index([trainRunId])
  @@schema("ktz")
}

model OperationalEvent {
  id        String               @id @default(uuid())
  stationId String
  type      OperationalEventType
  payload   Json                 @default("{}")
  createdAt DateTime             @default(now())

  station Station @relation(fields: [stationId], references: [id])

  @@schema("ktz")
}

model CrewCall {
  id                     String         @id @default(uuid())
  trainRunId             String
  crewId                 String?
  generatedFromVersionId String?
  mustReportAt           DateTime
  acceptedLocomotiveAt   DateTime
  status                 CrewCallStatus @default(PLANNED)
  notes                  String         @default("")
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  trainRun              TrainRun         @relation(fields: [trainRunId], references: [id])
  crew                  Crew?            @relation(fields: [crewId], references: [id])
  generatedFromVersion  ScheduleVersion? @relation(fields: [generatedFromVersionId], references: [id])

  @@unique([trainRunId, generatedFromVersionId])
  @@index([status, mustReportAt])
  @@index([crewId, mustReportAt])
  @@schema("ktz")
}

model Schedule {
  id            String   @id @default(uuid())
  trainId       String?
  trainNumber   String
  station       String
  arrival       DateTime?
  departure     DateTime?
  arrivalRaw    String?
  departureRaw  String?
  operation     String?
  sourceFile    String
  sourceSheet   String?
  sourceGroup   String?
  createdAt     DateTime @default(now())

  train Train? @relation(fields: [trainId], references: [id])

  @@index([trainNumber])
  @@index([station])
  @@index([departure])
  @@schema("ktz")
}

model ServiceSegment {
  id           String   @id @default(uuid())
  locoSeries   String
  startStation String
  endStation   String
  sourceFile   String
  createdAt    DateTime @default(now())

  @@index([locoSeries])
  @@index([startStation, endStation])
  @@schema("ktz")
}

model RefuelingPoint {
  id         String   @id @default(uuid())
  station    String   @unique
  fuel       Boolean?
  sand       Boolean?
  water      Boolean?
  notes      String?
  sourceFile String
  createdAt  DateTime @default(now())

  @@schema("ktz")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  payload     Json     @default("{}")
  createdAt   DateTime @default(now())

  @@schema("ktz")
}

// ─────────────────────────────────────────────
// BINDING DOMAIN: ENUMS
// ─────────────────────────────────────────────

enum BindingPlanStatus {
  DRAFT
  VALIDATED
  PLANNED
  CONFLICT
  REJECTED
  APPROVED

  @@schema("ktz")
}

enum InputFileStatus {
  UPLOADED
  VALIDATING
  VALIDATED
  FAILED
  PROCESSED

  @@schema("ktz")
}

enum ConflictCode {
  FORMAT_ERROR
  VALIDATION_ERROR
  REF_NOT_FOUND
  SHOULDER_NOT_RESOLVED
  MODEL_NOT_ALLOWED
  TIME_CONFLICT
  MAINTENANCE_VIOLATION
  SYSTEM_ERROR

  @@schema("ktz")
}

enum TractionType {
  ELECTRIC
  DIESEL
  DUAL

  @@schema("ktz")
}

enum MovementType {
  PASSENGER
  FREIGHT
  MIXED
  LIGHT

  @@schema("ktz")
}

// ─────────────────────────────────────────────
// BINDING DOMAIN: MDM/REFERENCE MODELS
// ─────────────────────────────────────────────

model InputFile {
  id         String          @id @default(uuid())
  fileName   String
  fileType   String          // e.g. "BindingPlan", "Locomotives", "ServiceShoulders"
  periodId   String?         // e.g. "2026-03" or "2025-2026"
  checksum   String          @unique
  status     InputFileStatus @default(UPLOADED)
  uploadedBy String?
  errorCount Int             @default(0)
  errorDetails Json          @default("[]") // row-level errors
  uploadedAt DateTime        @default(now())
  processedAt DateTime?

  bindingPlans BindingPlan[]

  @@index([status])
  @@index([periodId])
  @@schema("ktz")
}

model LocomotiveModel {
  id            String       @id @default(uuid())
  series        String       @unique
  sectionsCount Int          @default(1)
  tractionType  TractionType @default(DIESEL)
  description   String?
  createdAt     DateTime     @default(now())

  shoulders        ServiceShoulder[]
  maintenanceRules MaintenanceRule[]
  bindingPlans     BindingPlan[]

  @@schema("ktz")
}

model ServiceShoulder {
  id              String       @id @default(uuid())
  depotId         String
  fromStationId   String
  toStationId     String
  modelId         String
  sectionsCount   Int          @default(1)
  movementType    MovementType @default(MIXED)
  createdAt       DateTime     @default(now())

  depot       Depot           @relation(fields: [depotId], references: [id])
  fromStation Station         @relation("ShoulderFrom", fields: [fromStationId], references: [id])
  toStation   Station         @relation("ShoulderTo", fields: [toStationId], references: [id])
  model       LocomotiveModel @relation(fields: [modelId], references: [id])

  bindingPlans BindingPlan[]

  @@unique([depotId, fromStationId, toStationId, modelId, sectionsCount])
  @@index([fromStationId, toStationId])
  @@schema("ktz")
}

model MaintenanceRule {
  id                   String @id @default(uuid())
  modelId              String
  to2KmMin             Int?
  to2KmMax             Int?
  to2DowntimeHours     Int?
  serviceKmMin         Int?
  serviceKmMax         Int?
  serviceDowntimeHours Int?
  createdAt            DateTime @default(now())

  model LocomotiveModel @relation(fields: [modelId], references: [id])

  @@index([modelId])
  @@schema("ktz")
}

model Route {
  id        String   @id @default(uuid())
  trainId   String
  validFrom DateTime
  validTo   DateTime
  createdAt DateTime @default(now())

  train Train      @relation(fields: [trainId], references: [id])
  stops RouteStop[]

  @@index([trainId])
  @@schema("ktz")
}

model RouteStop {
  id           String    @id @default(uuid())
  routeId      String
  stationId    String
  seqNo        Int
  stationCode  String?
  arrivalDt    DateTime?
  departureDt  DateTime?
  stopMinutes  Int?
  distanceKm   Int?

  route   Route   @relation(fields: [routeId], references: [id])
  station Station @relation(fields: [stationId], references: [id])

  @@index([routeId, seqNo])
  @@schema("ktz")
}

// ─────────────────────────────────────────────
// BINDING DOMAIN: PLANNING MODELS
// ─────────────────────────────────────────────

model BindingPlan {
  id                   String            @id @default(uuid())
  periodId             String
  turnaroundStationId  String
  arrivalTrainId       String
  arrivalDt            DateTime
  departureTrainId     String
  departureDt          DateTime
  dwellMinutes         Int               @default(0)
  shoulderId           String?
  requiredModelId      String?
  status               BindingPlanStatus @default(DRAFT)
  conflictReasonCode   String?
  conflictReasonDetails String?
  sourceFileId         String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  turnaroundStation Station          @relation("BindingTurnaround", fields: [turnaroundStationId], references: [id])
  arrivalTrain      Train            @relation("BindingArrival", fields: [arrivalTrainId], references: [id])
  departureTrain    Train            @relation("BindingDeparture", fields: [departureTrainId], references: [id])
  shoulder          ServiceShoulder? @relation(fields: [shoulderId], references: [id])
  requiredModel     LocomotiveModel? @relation(fields: [requiredModelId], references: [id])
  sourceFile        InputFile?       @relation(fields: [sourceFileId], references: [id])

  allocations BindingAllocation[]
  conflicts   BindingConflict[]

  @@unique([periodId, turnaroundStationId, arrivalTrainId, departureTrainId, arrivalDt])
  @@index([periodId])
  @@index([status])
  @@index([turnaroundStationId])
  @@schema("ktz")
}

model BindingAllocation {
  id             String   @id @default(uuid())
  bindingId      String
  locomotiveId   String
  allocatedFrom  DateTime
  allocatedTo    DateTime
  status         String   @default("ACTIVE") // ACTIVE, RELEASED, CANCELLED
  createdAt      DateTime @default(now())

  binding    BindingPlan @relation(fields: [bindingId], references: [id])
  locomotive Locomotive  @relation(fields: [locomotiveId], references: [id])

  @@index([bindingId])
  @@index([locomotiveId, allocatedFrom, allocatedTo])
  @@schema("ktz")
}

model BindingConflict {
  id         String       @id @default(uuid())
  bindingId  String
  code       ConflictCode
  details    String?
  detectedAt DateTime     @default(now())

  binding BindingPlan @relation(fields: [bindingId], references: [id])

  @@index([bindingId])
  @@index([code])
  @@schema("ktz")
}

model KpiSnapshot {
  id           String   @id @default(uuid())
  periodId     String
  scopeType    String   // "station", "depot", "shoulder", "global"
  scopeId      String?  // station_id, depot_id, etc.
  idleRatio    Float    @default(0)
  utilization  Float    @default(0)
  conflictsCnt Int      @default(0)
  avgDwell     Float    @default(0)
  maxDwell     Float    @default(0)
  calculatedAt DateTime @default(now())

  @@index([periodId, scopeType])
  @@schema("ktz")
}
